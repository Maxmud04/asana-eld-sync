# Copy this file to ".env" and fill in your own real values.
# Never share your real .env file or commit it anywhere public.

# --- Asana ---
ASANA_TOKEN=your-asana-personal-access-token
# Comma-separated list of Asana project IDs to sync into.
ASANA_PROJECT_IDS=111111111111111,222222222222222,333333333333333

# --- Factor ELD ---
# See eld_factor.py for how this token is obtained (temporary, expires
# roughly every 24 hours until automatic login is added).
FACTOR_SESSION_TOKEN=
FACTOR_TENANT_ID=
# Optional: comma-separated Factor ELD company IDs to restrict syncing to.
# Leave empty to sync every company.
FACTOR_COMPANY_FILTER=

# --- Leader ELD (not set up yet) ---
LEADER_API_KEY=

# --- Telegram control bot (optional - pause/resume/status) ---
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to control the bot. Leave empty
# to allow EVERY Telegram account to control it (no allowlist) - only do
# that if you really mean for anyone to be able to /pause, /resume, or
# /settoken. List specific IDs here to restrict it instead.
ALLOWED_TELEGRAM_IDS=

# --- Schedule ---
POLL_INTERVAL_MINUTES=5
