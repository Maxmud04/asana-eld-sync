# control_bot's own config - separate from any team's teams/<team_id>/.env.
# Copy this to control_bot/.env and fill in real values.

# The ONE shared Telegram bot token - this process is the only thing
# allowed to long-poll it (see gateway.py). Per-team sync.py processes
# reuse this same token only for OUTBOUND alerts (see telegram_notifier.py).
CONTROL_BOT_TELEGRAM_TOKEN=

# Optional overrides - sensible defaults are relative to this directory.
# CONFIG_DB_PATH=./config.db
# CONFIG_MASTER_KEY_PATH=./master.key   # back this up somewhere durable -
#                                        # losing it makes every stored
#                                        # team token unrecoverable.
# TEAMS_ROOT_DIR=../teams
